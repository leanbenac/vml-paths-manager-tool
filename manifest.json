{
  "manifest_version": 3,
  "name": "VML Paths Manager Tool",
  "version": "1.0",
  "description": "Suite de herramientas de gestión de publish paths para Project Managers, Leads y Publishers de VML.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "*://jira.uhub.biz/*",
    "*://*.atlassian.net/*"
  ],
  "action": {
    "default_popup": "core/popup.html",
    "default_icon": "assets/logo-vml.png"
  },
  "icons": {
    "128": "assets/logo-vml.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "modules/publish-path-generator/content-publish-path-generator.js"
      ],
      "css": [
        "core/content.css"
      ],
      "all_frames": true
    },
    {
      "matches": [
        "*://jira.uhub.biz/*",
        "*://*.atlassian.net/*"
      ],
      "js": [
        "modules/jira-path-parser/content-jira-parser.js"
      ],
      "all_frames": true
    }
  ]
}
